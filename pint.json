{
    "preset": "laravel",
    "exclude": [
        "bootstrap",
        "public",
        "lang"
    ],
    "rules": {
        "declare_strict_types": true,
        "group_import": true,
        "single_import_per_statement": false,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true
    }
}
